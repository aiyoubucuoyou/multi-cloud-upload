{
  "manifest_version": 3,
  "name": "多网盘上传助手",
  "version": "1.20260408",
  "description": "一键上传文件到百度网盘、夸克网盘、123盘",
  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "scripting",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://pan.baidu.com/*",
    "https://pan.quark.cn/*",
    "https://www.123pan.com/*",
    "https://yun.123pan.cn/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://pan.baidu.com/*"],
      "js": ["content/baidu-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://pan.quark.cn/*"],
      "js": ["content/quark-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.123pan.com/*", "https://yun.123pan.cn/*"],
      "js": ["content/123pan-content.js"],
      "run_at": "document_idle"
    }
  ]
}
